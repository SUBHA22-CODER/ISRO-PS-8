# Environment variables for POLARIS
# Copy this file to .env and fill in values

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8050
BACKEND_URL=http://localhost:8000

# Data paths
DATA_DIR=./data
PROCESSED_DIR=./data/processed
DEMO_DIR=./data/demo

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/polaris.db

# Pipeline config
CONFIG_PATH=./configs/pipeline_config.yaml
